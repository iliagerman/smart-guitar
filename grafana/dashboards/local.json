      "id": 3,
      "options": {
        "barWidth": 0.8,
        "orientation": "horizontal",
        "showValue": "always"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "smart-guitar-loki"
          },
          "expr": "sum by (service) (count_over_time({environment=\"local-dev\", service=~\"${service:pipe}\"} [$__range]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Service",
      "type": "barchart"
    }
