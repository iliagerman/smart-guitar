        "y": 18
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "smart-guitar-loki"
          },
          "expr": "sum(count_over_time({environment=\"local-dev\", service=~\"${service:pipe}\", level=\"ERROR\"} [5m]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ],
      "title": "Error Count Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
