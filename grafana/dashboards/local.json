          "refId": "A"
        }
      ],
      "title": "Log Stream",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "format": "kvp"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "id": true,
              "tsNs": true,
              "labels": true,
              "environment": true,
              "log_source": true,
              "label_type": true,
              "filename": true
            },
            "renameByName": {
              "Line": "msg",
              "request_id": "rid",
              "user_id": "uid"
            },
            "indexByName": {
              "Time": 0,
              "service": 1,
              "level": 2,
              "rid": 3,
              "uid": 4,
              "msg": 5
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "smart-guitar-loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
